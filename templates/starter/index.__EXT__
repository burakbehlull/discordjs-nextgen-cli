import { App, Intents } from 'discordjs-nextgen';
import "dotenv/config";

const app = new App({
    intents: Intents.ALL
});

app.setPresence({
    status: 'idle',
    activities: [
        {
            name: 'NextGen',
            type: 0,
            url: null,
        },
    ],
});

app.run(process.env.TOKEN);
